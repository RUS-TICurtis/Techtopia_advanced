  "components": {
    "schemas": {
      "AcceptInvitationRequest": {
        "required": [
          "token",
          "password",
          "firstName",
          "lastName"
        ],
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          }
        }
      },
      "AccountCategory": {
        "enum": [
          "Cash",
          "Bank",
          "AccountsReceivable",
          "AccountsPayable",
          "Revenue",
          "Expense",
          "Tax",
          "Inventory",
          "Payroll",
          "Equity",
          "FixedAsset",
          "Depreciation"
        ]
      },
      "AccountType": {
        "enum": [
          "Asset",
          "Liability",
          "Equity",
          "Revenue",
          "Expense"
        ]
      },
      "ActivityType": {
        "enum": [
          "Call",
          "Email",
          "Meeting",
          "SMS",
          "WhatsApp",
          "Demo",
          "Note"
        ]
      },
      "ApprovalDecision": {
        "enum": [
          "Pending",
          "Approved",
          "Rejected"
        ]
      },
      "ApproveInvoiceRequest": {
        "required": [
          "comment",
          "status"
        ],
        "type": "object",
        "properties": {
          "comment": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "$ref": "#/components/schemas/InvoiceApprovalStatus"
          }
        }
      },
      "AssignLeadRequest": {
        "type": "object",
        "properties": {
          "assignedToId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "BudgetApproveRequest": {
        "required": [
          "comment"
        ],
        "type": "object",
        "properties": {
          "comment": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "BudgetCloseRequest": {
        "required": [
          "comment"
        ],
        "type": "object",
        "properties": {
          "comment": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "BudgetSubmitRequest": {
        "required": [
          "comment"
        ],
        "type": "object",
        "properties": {
          "comment": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "BudgetType": {
        "enum": [
          "Annual",
          "Quarterly",
          "Monthly",
          "Project",
          "Department",
          "Operational",
          "CapitalExpenditure"
        ]
      },
      "ConvertLeadRequest": {
        "type": "object",
        "properties": {
          "companyName": {
            "type": "string"
          },
          "opportunityName": {
            "type": "string"
          }
        }
      },
      "CreateAccountDto": {
        "type": "object",
        "properties": {
          "accountCode": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/AccountType"
          },
          "category": {
            "$ref": "#/components/schemas/AccountCategory"
          },
          "parentAccountId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          }
        }
      },
      "CreateBudgetAllocationRequest": {
        "required": [
          "allocationName",
          "allocatedAmount"
        ],
        "type": "object",
        "properties": {
          "allocationName": {
            "type": "string"
          },
          "allocatedAmount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "CreateBudgetRequest": {
        "required": [
          "name",
          "description",
          "type",
          "startDate",
          "endDate",
          "totalAmount"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "type": {
            "$ref": "#/components/schemas/BudgetType"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "totalAmount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "CreateExpenseRequest": {
        "required": [
          "categoryId",
          "vendorId",
          "budgetId",
          "projectId",
          "opportunityId",
          "expenseDate",
          "amount",
          "currency",
          "description"
        ],
        "type": "object",
        "properties": {
          "categoryId": {
            "type": "string",
            "format": "uuid"
          },
          "vendorId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "budgetId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "projectId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "opportunityId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "expenseDate": {
            "type": "string",
            "format": "date-time"
          },
          "amount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "currency": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "CreateInvitationRequest": {
        "required": [
          "email",
          "roleId"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "roleId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "CreateInvoiceItemRequest": {
        "required": [
          "description",
          "quantity",
          "unitPrice",
          "taxRate",
          "discountRate"
        ],
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "quantity": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "unitPrice": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
